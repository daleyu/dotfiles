[fetch]
    prune = true

[pull]
    rebase = true

[core]
    pager = delta
	editor = nvim

[interactive]
    diffFilter = delta

[merge]
    conflictstyle = zdiff3

[include]
    path = ~/.config/delta/.gitconfig
	path = ~/.config/delta/catppuccin.gitconfig

[diff]
    tool = nvim_difftool

[difftool "nvim_difftool"]
    cmd = nvim -c \"packadd nvim.difftool\" -c \"DiffTool $LOCAL $REMOTE\"
