[fetch]
    prune = true

[pull]
    rebase = true

[core]
    pager = delta
    editor = nvim

[help]
    # Automatically correct and execute mistyped commands such as `git stauts`
    autocorrect = 1

[interactive]
    diffFilter = delta

[merge]
    conflictstyle = zdiff3

[include]
    path = ~/.config/delta/.gitconfig
    path = ~/.config/delta/catppuccin.gitconfig

[alias]
    bring = "!f() { if [ $# -eq 1 ]; then git fetch origin +refs/heads/$1:refs/remotes/origin/$1 && git checkout -B $1 FETCH_HEAD && git config branch.$1.remote origin && git config branch.$1.merge refs/heads/$1 && echo \"Branch '$1' is now checked out and configured to track origin/$1.\"; else echo 'Usage: git bring <branch_name>'; fi; }; f"
    snatch = "!f() { if [ $# -eq 2 ]; then git fetch origin \"$1\" && git checkout -b \"$2\" FETCH_HEAD && echo \"Stole origin/'$1' and created your new branch '$2'.\"; else echo 'Usage: git snatch <their_branch> <your_new_branch>'; fi; }; f"
    latest = "!f() { git log --format=\"%H %ae\" | grep -v \"$(git config user.email)\" | head -n 1 | awk \"{print \$1}\"; }; f"
    dt = !GIT_EXTERNAL_DIFF=difft git diff


# Diff and merge
[diff]
    algorithm = histogram
    colorMoved = true
    colorMovedWS = allow-indentation-change
    mnemonicPrefix = true

    tool = nvim_difftool
    submodule = diff

[diff "bin"]
    textconv = hexdump -v -C

[difftool]
    prompt = true
    trustExitCode = true

[difftool "nvim_difftool"]
    cmd = nvim -c \"packadd nvim.difftool\" -d \"$LOCAL\" \"$REMOTE\"

[merge]
    log = true
    tool = nvimdiff1
    conflictstyle = zdiff3

[mergetool]
    prompt = true
    trustExitCode = true
    hideResolved = true
